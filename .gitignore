# Dependency Directories (Matches any node_modules folder recursively)
node_modules/

# Production Build Directories
dist/
dist-ssr/
build/
out/

# TypeScript Build Info Caches
*.tsbuildinfo

# Debugging Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and Secret Variables (Should NEVER be committed to Git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Operating System Files
.DS_Store
Thumbs.db

# IDE and Editor Workspace Configurations
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.user
